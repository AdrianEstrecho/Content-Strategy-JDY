# ---- Local DB (SQLite) ----
DATABASE_URL="file:./dev.db"

# ---- Anthropic (Claude API) ----
# Agents run in stub mode when this is blank. Set it to enable real Claude calls.
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Default model for all 4 agents. Update as Anthropic releases newer models.
ANTHROPIC_MODEL="claude-sonnet-4-6"

# ---- Instagram Graph API (optional — stubbed by default) ----
# Requires a Meta for Developers app, a Facebook Page, and an Instagram Business account.
# Scopes needed: instagram_basic, instagram_manage_insights, pages_read_engagement
IG_ACCESS_TOKEN=
IG_BUSINESS_ACCOUNT_ID=

# ---- Single-user auth (simple passphrase gate) ----
# APP_PASSPHRASE: the secret a visitor must type at /login. Leave blank to disable
# the gate entirely (anyone with the URL gets in — fine for localhost).
APP_PASSPHRASE=
# SESSION_SECRET: signs the auth cookie. Required when APP_PASSPHRASE is set.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=
